---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | wagetheftcalc.com';
const description = 'Privacy policy for wagetheftcalc.com — how we collect, use, and protect visitor information.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026<br />
  <strong>Last updated:</strong> May 2026</p>

  <p>wagetheftcalc.com is operated by The Click Lab. This policy explains what information is collected when you visit the site and how it is used.</p>

  <h2>Information we collect directly</h2>
  <p>We do not collect personally identifiable information from visitors. Calculator inputs (hourly rate, hours, violation type) are processed in your browser and never transmitted to our servers. If you email us, we receive your address and message content, used only to respond.</p>

  <h2>Third-party services</h2>
  <h3>Google AdSense</h3>
  <p>We display advertising through Google AdSense (pub-6434377544325972). AdSense uses cookies to serve relevant ads. Opt out at <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>. Google&rsquo;s privacy policy: <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">policies.google.com/privacy</a>.</p>

  <h3>Google Analytics</h3>
  <p>We use Google Analytics 4 for aggregate traffic data. Data is not linked to individual visitors. Opt out via the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics Opt-out Add-on</a>.</p>

  <h2>Cookies</h2>
  <p>We do not set first-party cookies. AdSense and Analytics set third-party cookies as described above. You can block cookies through browser settings without affecting calculator or guide functionality.</p>

  <h2>California residents (CCPA)</h2>
  <p>We do not directly collect personal information from visitors. For requests related to any personal data we hold (e.g., email correspondence), contact <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <h2>Children&rsquo;s privacy</h2>
  <p>This site is not directed to children under 13. We do not knowingly collect data from children.</p>

  <h2>Changes to this policy</h2>
  <p>We may update this policy as practices or law changes. The &ldquo;Last updated&rdquo; date reflects the most recent revision.</p>

  <h2>Contact</h2>
  <p>Questions? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>

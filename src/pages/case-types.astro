---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Types of Wage Theft | wagetheftcalc.com';
const description = 'Common types of wage theft: unpaid overtime, minimum wage violations, tip theft, misclassification, and more.';
---
<BaseLayout title={title} description={description}>
  <h1>Types of Wage Theft</h1>

  <h2>Unpaid Overtime</h2>
  <p>The FLSA requires time-and-a-half pay for hours over 40 per week for non-exempt employees. Common violations include misclassifying employees as exempt, altering time records, and pressuring employees to work "off the books."</p>

  <h2>Minimum Wage Violations</h2>
  <p>Paying below the applicable minimum wage (federal $7.25/hr; many states/cities higher). Includes illegal deductions that bring effective pay below minimum wage.</p>

  <h2>Off-the-Clock Work</h2>
  <p>Requiring employees to work before clocking in, after clocking out, during meal breaks, or to perform prep/cleanup without pay. Automatic time deductions that don't match actual break time are a common form.</p>

  <h2>Tip Theft</h2>
  <p>Employers or managers taking tips, invalid tip pool arrangements (including managers), and credit card processing fee deductions from tips. The FLSA prohibits employer tip-taking under any circumstances.</p>

  <h2>Employee Misclassification</h2>
  <p>Labeling employees as independent contractors to avoid overtime, minimum wage, and benefits obligations. The economic reality test — not an employer's label — determines worker status.</p>

  <h2>Final Paycheck Violations</h2>
  <p>Failing to pay earned wages on termination in a timely manner. Most states require final paychecks within days of separation; penalties for delay vary by state.</p>

  <h2>Illegal Deductions</h2>
  <p>Deducting from wages for register shortages, uniform costs, or damages in ways that bring pay below minimum wage. Federal and state laws restrict permissible paycheck deductions.</p>
</BaseLayout>
